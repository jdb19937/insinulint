# Faceplica — insinulint, lintor linguae C
#
# Solum instrumenta POSIX et compilator C requiruntur.

APOTHECA ?= .

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2
CFLAGS  += -I$(APOTHECA)/ison
LDFLAGS =

INSPECTIONES = inspectiones/auxiliaria.c \
	inspectiones/indentatio.c \
	inspectiones/spatia_terminalia.c \
	inspectiones/longitudo.c \
	inspectiones/lineae_vacuae.c \
	inspectiones/finis.c \
	inspectiones/tabulae_mixtae.c \
	inspectiones/spatia_verborum.c \
	inspectiones/spatia_operatorum.c \
	inspectiones/virgulae.c \
	inspectiones/semicolona.c \
	inspectiones/cubitus.c \
	inspectiones/bracchia_stilus.c \
	inspectiones/bracchia_necessaria.c \
	inspectiones/colineatio.c \
	inspectiones/commentaria.c \
	inspectiones/corpus_separatum.c \
	inspectiones/una_sententia.c

CORRECTIONES = correctiones/communes.c \
	correctiones/corpus.c \
	correctiones/apertio.c \
	correctiones/scissio.c \
	correctiones/colineatio.c \
	correctiones/excommenta.c \
	correctiones/bracchia.c \
	correctiones/una_sententia.c \
	correctiones/virgula.c \
	correctiones/cubitus.c \
	correctiones/operatores.c \
	correctiones/verbum.c \
	correctiones/semicolon.c \
	correctiones/longitudo.c

CAPITA  = insinulint.h inspectio.h correctio.h commendatio.h

FONTES  = insinulint.c lexator.c inspectio.c correctio.c commendatio.c $(INSPECTIONES) $(CORRECTIONES)
OBJECTA = $(FONTES:.c=.o)
NOMEN   = insinulint

# bibliothecae externae
LIBISON = $(APOTHECA)/ison/libison.a

PROBA_FONTES = proba.c lexator.c inspectio.c correctio.c commendatio.c $(INSPECTIONES) $(CORRECTIONES)
PROBA_OBJECTA = $(PROBA_FONTES:.c=.o)

omnia: $(NOMEN)

para:
	git submodule update --init ison
	$(FACE) -C ison

expara:
	git submodule deinit -f ison

$(LIBISON):
	$(FACE) -C $(APOTHECA)/ison

$(LIBCRISPUS):
	$(FACE) -C $(APOTHECA)/crispus

$(NOMEN): $(OBJECTA) $(LIBISON)
	$(CC) $(LDFLAGS) -o $@ $^

proba: $(PROBA_OBJECTA) $(LIBISON)
	$(CC) $(LDFLAGS) -o $@ $(PROBA_OBJECTA) $(LIBISON)
	./$@

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o $@ $<

purga:
	rm -f $(OBJECTA) $(PROBA_OBJECTA) $(NOMEN) proba
	rm -rf artificia

linte:
	./insinulint -c $(FONTES)

.PHONY: omnia purga proba para expara inspice linte
